# P7 cloud credentials — copy to `.env` and fill in (`.env` is gitignored).
# P7b official provider per docs/p7-cloud-runbook.md: RunPod on the exact
# runpod-a100-v1 profile. Thunder Compute is retained only for reproducing
# historical comparative measurements. Vast.ai remains optional for
# non-gating throwaway roofline runs.

# Thunder Compute — https://console.thundercompute.com (Settings → API tokens);
# used by the `tnr` CLI (pip install tnr; `tnr login` reads this).
TNR_API_TOKEN=

# RunPod — https://www.runpod.io/console/user/settings → API Keys;
# used by runpodctl / the REST API to create pods programmatically.
RUNPOD_API_KEY=

# Vast.ai (optional) — https://cloud.vast.ai → Account → API key.
VAST_API_KEY=

# Hugging Face token: NOT needed for gpt2 (public repo, anonymous download
# works); fill only if the box hits rate limits or a gated model is added.
HF_TOKEN=

# SSH key the cloud boxes get provisioned with (public key uploaded to the
# provider console once; the private key never leaves this machine).
CLOUD_SSH_KEY=~/.ssh/id_ed25519_github

# Current/next cloud box connection. These are read by local helper scripts
# such as `scripts/cloud_pull_results.sh`; keep real values only in `.env`.
CLOUD_PROVIDER=runpod
CLOUD_USER=ubuntu
CLOUD_HOST=
CLOUD_PORT=22
CLOUD_REMOTE_REPO=/home/ubuntu/volta-zk
